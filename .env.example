# =============================================================================
# AMFTA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it is in .gitignore).

# ---------------------------------------------------------------------------
# Experiment Overrides (Optional)
# ---------------------------------------------------------------------------
AMFTA_NUM_CLIENTS=100
AMFTA_NUM_ROUNDS=100
AMFTA_BYZ_FRACTION=0.30
AMFTA_ATTACK_TYPE=label_flipping
AMFTA_SEED=42
AMFTA_USE_SYNTHETIC=false
AMFTA_RESULTS_DIR=results

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------
MODEL_CHECKPOINT_PATH=checkpoints/amfta_best.pt
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ---------------------------------------------------------------------------
# Experiment Tracking (Optional)
# ---------------------------------------------------------------------------
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=amfta_experiments

# WANDB_API_KEY=your_wandb_api_key_here
# WANDB_PROJECT=amfta-fl
# WANDB_ENTITY=your_team_name

# ---------------------------------------------------------------------------
# PyTorch
# ---------------------------------------------------------------------------
# Force CPU (disable GPU):
# CUDA_VISIBLE_DEVICES=""
# Use specific GPU:
# CUDA_VISIBLE_DEVICES=0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FILE=logs/amfta.log
